#!/bin/bash

rm /tmp/myvoice.wav /tmp/data.txt

mpv /home/akash/.local/share/sound/voicesearch.wav
notify-send -r 2  -t 0 "Listening.." &

ffmpeg -y -f alsa -i default -acodec pcm_s16le -ac 1 -ar 44100 -t 10 -f wav /tmp/myvoice.wav

notify-send -r 2 "tranlating"
vosk-transcriber -m "/home/akash/.config/vosk-model-hi-0.22" -i /tmp/myvoice.wav -o /tmp/data.txt

if [[ -z "$(cat /tmp/data.txt)" ]]; then
  echo "Exiting.."
 exit 
fi

notify-send -r 2 -t 0 "$(cat /tmp/data.txt)"

google_speech "Ok, Playing $(cat /tmp/data.txt)" &

query="$(cat /tmp/data.txt)"

#url=$(yt-dlp  -f bestaudio "ytsearch2:$query" --get-url  | head -n 1 )
#url=$(yt-dlp  -f bestvideo[ext=mp4]+bestaudio[ext=m4a]  "ytsearch2:$query" --get-url  | head -n 1 )
url="https://youtube.com/watch?v=$(yt-dlp "ytsearch2:$query" --get-id)"

notify-send -r 2  "$url"
mpv "$url"
#notify-send -r 2 -t 0 "Playing $query \n Press F4 to stop."

