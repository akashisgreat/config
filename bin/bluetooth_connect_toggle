#!/bin/sh
# This shell script is PUBLIC DOMAIN. You may do whatever you want with it.
MAC="FC:58:FA:8B:98:9D"

TOGGLE=$HOME/.cache/bluetooth_connect_toggle

if [ ! -e $TOGGLE ]; then
    touch $TOGGLE
    bluetoothctl connect $MAC
    notify-send -r 1 "Connecting now"
else
    rm $TOGGLE
    bluetoothctl disconnect $MAC
    notify-send -r 1 "Disconnecting now"
fi

