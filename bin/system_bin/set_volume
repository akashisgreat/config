#!/bin/bash
if [[ -z $2 ]]; then
  value=5
else
  value=$2
fi

if [[ $1 == "-t" ]]; then
  pamixer -t
  status="$(pamixer --get-mute | sed 's/true/🔇 Muted/;s/false/🔇 Unmuted/')"
else
  if [[ $1 == '+' ]]; then
    pamixer -i $value
  else
    pamixer -d $value
  fi
curr_vol=$(pamixer --get-volume)
status="-h int:value:$curr_vol Volume $curr_vol"
fi
notify-send -r 1 $status
